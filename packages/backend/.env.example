# Backend environment variables — copy to `.env` and fill in real values.
NODE_ENV=development
JWT_SECRET=replace-me-openssl-rand-base64-64
JWT_REFRESH_SECRET=replace-me-openssl-rand-base64-64
ENCRYPT_KEY=replace-me-openssl-rand-hex-32
GOOGLE_CLIENT_ID=dev-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=dev-google-client-secret
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost,https://localhost,capacitor://localhost,http://localhost:5173
RESEND_API_KEY=re_replace_me
WAITLIST_FROM_EMAIL="Your Name <you@yourdomain.example>"
WAITLIST_REPLY_TO="you@yourdomain.example"
DB_PATH=/path/to/waitlist.db
