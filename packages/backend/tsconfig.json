{
    "compilerOptions": {
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "paths": {
            "@KiwiClient/shared": [
                "../shared/src/index.ts"
            ]
        }
    },
    "include": [
        "src"
    ],
    "references": [
        {
            "path": "../shared"
        }
    ]
}
